        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WevilTimer_Desctop"
        mc:Ignorable="d"
        WindowStyle="None"
        Background="#282828"
        Title="PreloaderWindow" Height="450" Width="800" MinHeight="450" MinWidth="800">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" > 
        <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="Inter" FontSize="32" Foreground="#3500D4">Wewil</TextBlock>
            <TextBlock FontFamily="Inter" FontSize="32" Foreground="#B6B6B6">Timer</TextBlock>
        </StackPanel>
    </Grid>
</Window>