<Window x:Class="WevilTimer_Desctop.PreloaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WevilTimer_Desctop"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="PreloaderWindow" Height="450" Width="800" Background="#282828">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"> 
        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="32"  Foreground="#3500D4" >Wevil</TextBlock>
            <TextBlock FontSize="32" Foreground="#B6B6B6">Timer</TextBlock>
        </StackPanel>
    </Grid>
</Window>
